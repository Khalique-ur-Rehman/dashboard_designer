<odoo>
    <!-- Client action for the Dashboard Home screen -->
    <record id="action_dashboard_home" model="ir.actions.client">
        <field name="name">Dashboard Home</field>
        <field name="tag">dashboard_home_client_action</field>
    </record>

    <!-- "Home" menu under the main Dashboards menu -->
    <menuitem id="menu_dashboard_home"
              name="Home"
              parent="dashboard_designer.menu_dashboard_root"
              action="action_dashboard_home"
              sequence="5"/>
</odoo>