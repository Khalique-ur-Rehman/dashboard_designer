<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_dashboard" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.dashboard.designer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data-string="Dashboard Designer"
                     string="Dashboard Designer"
                     data-key="dashboard_designer" id="dashboard_designer_settings">
                    <h2>AI Insights Configuration</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="dashboard_ai_api_key" password="True"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="dashboard_ai_api_key"/>
                                <div class="text-muted">
                                    Enter your AI service API key (e.g., OpenAI API key)
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="dashboard_ai_api_key"
                                               password="True"
                                               placeholder="sk-..."/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="dashboard_ai_endpoint"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="dashboard_ai_endpoint"/>
                                <div class="text-muted">
                                    API endpoint URL for AI service
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="dashboard_ai_endpoint"
                                               placeholder="https://api.openai.com/v1/chat/completions"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="dashboard_ai_model"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="dashboard_ai_model"/>
                                <div class="text-muted">
                                    AI model to use for generating insights
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="dashboard_ai_model"
                                               placeholder="gpt-4o-mini"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>